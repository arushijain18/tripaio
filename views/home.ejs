<% layout(false) %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TripAIO — Embrace the Journey</title>
   
<link rel="icon" href="/images/favicon.png">

<link rel="apple-touch-icon" sizes="180x180" href="/images/favicon.png">

<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
<div id="debug-user" data-user="<%= locals.currUser ? locals.currUser.username : 'NOBODY' %>" style="display:none"></div>

  <!-- NAVBAR -->
<nav class="home-nav" id="nav">
  <a href="/" class="logo">TRIPAIO</a>
  <div class="nav-links">
    <a href="/listings">Staycations</a>
    <a href="/trip/plan">Plan Trip</a>
    <a href="/trip/saved">My Trips</a>
    <a href="/trip/budget">Budget</a>
  </div>
  <div class="nav-auth" id="navAuth">
<% if(locals.currUser) { %>
  <a href="/listings">Hi, <%= currUser.username %></a>
  <a href="/logout" class="btn-getstarted">Logout</a>
<% } else { %>
  <a href="/login" id="signinBtn">Sign In</a>
  <a href="/signup" class="btn-getstarted" id="signupBtn">Get Started</a>
<% } %>
<!-- DEBUG: currUser = <%= JSON.stringify(locals.currUser) %> -->
  </div>
</nav>

<% if(locals.highlight && highlight) { %>
<style>
  @keyframes btnPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(201,162,39,.7); }
    50% { box-shadow: 0 0 0 10px rgba(201,162,39,0); }
  }
  #signinBtn { color: var(--gold) !important; font-weight:700 !important; }
  #signupBtn { animation: btnPulse 1s ease 3; background:var(--gold); border-color:var(--gold); color:var(--brown) !important; }
</style>
<% } %>

<!-- HERO -->
<section class="hero">
  <div class="hero-img"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <span class="hero-label">Royal Wanderer</span>
    <h1 class="hero-title">TripAIO</h1>
    <p class="hero-tagline">Embrace the journey,<br>for it shapes the destination.</p>
    <div class="hero-btns">
      <a href="/listings" class="btn-hero-primary">Explore Stays</a>
      <a href="/trip/plan" class="btn-hero-secondary">Plan Journey</a>
    </div>
  </div>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- CHOOSE YOUR STAYCATION -->
<section class="choose-section">
  <div class="section-header">
    <h2>Choose Your Staycation</h2>
    <p>Select your travel mood and let us curate the perfect escape.</p>
  </div>
  <div class="cat-cards">
    <% [
  ['/listings/category/beachfront','linear-gradient(160deg,#023E8A,#00B4D8)','fa-umbrella-beach','Coastal Dreamer','Beachfront','Wake up to the sound of waves.','https://images.unsplash.com/photo-1507525428034-b723cf961d3e'],

  ['/listings/category/mountains','linear-gradient(160deg,#1B4332,#52B788)','fa-mountain','Alpine Seeker','Mountains','Above the clouds.','https://images.unsplash.com/photo-1501785888041-af3ef285b470'],

  ['/listings/category/castle','linear-gradient(160deg,#4A1942,#C17B7B)','fa-chess-rook','Heritage Explorer','Castle','Live like royalty.','https://images.unsplash.com/photo-1568605114967-8130f3a36994'],

  ['/listings/category/amazing pools','linear-gradient(160deg,#1A535C,#4ECDC4)','fa-water','Luxury Retreat','Amazing Pools','Infinity pools & villas.','https://images.unsplash.com/photo-1571896349842-33c89424de2d'],

  ['/listings/category/camping','linear-gradient(160deg,#5C4033,#C4A882)','fa-campground','Wild Adventurer','Camping','Bonfire & tents.','https://images.unsplash.com/photo-1504280390367-361c6d9f38f4'],

  ['/listings/category/farm','linear-gradient(160deg,#4A5240,#DBBE89)','fa-tractor','Rural Escape','Farm','Countryside living.','https://images.unsplash.com/photo-1500382017468-9049fed747ef'],

  ['/listings/category/cities','linear-gradient(160deg,#1C1C2E,#C9A227)','fa-city','City Explorer','Cities','Urban vibes.','https://images.unsplash.com/photo-1494526585095-c41746248156'],

  ['/listings/category/trending','linear-gradient(160deg,#D2691E,#F5E6C8)','fa-fire','What\'s Hot','Trending','Popular stays.','https://images.unsplash.com/photo-1469474968028-56623f02e42e'],

  ['/listings/category/arctic','linear-gradient(160deg,#1D3557,#A8DADC)','fa-snowflake','Winter Wanderer','Arctic','Snow cabins.','https://images.unsplash.com/photo-1482192596544-9eb780fc7f66'],

  ['/listings/category/rooms','linear-gradient(160deg,#6D4C41,#EFEBE9)','fa-bed','Cozy Stays','Rooms','Comfort rooms.','https://images.unsplash.com/photo-1505691938895-1758d7feb511']
].forEach(([href,bg,icon,mood,title,desc,img]) => { %> 
      <a href="<%= href %>" class="cat-card">
         <div class="cat-bg" style="background-image:url('<%= img %>')"></div>

        <i class="fas <%= icon %> cat-icon"></i>
        <div class="cat-body">
          <span class="cat-mood"><%= mood %></span>
          <h3><%= title %></h3>
          <p><%= desc %></p>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<!-- FEATURED DESTINATIONS -->
<section class="featured-section">
  <div class="section-header">
    <h2>Featured Destinations</h2>
    <p>Handpicked stays from across the world</p>
  </div>
  <div class="dest-grid">
    <% if(typeof featured !== 'undefined' && featured.length) { %>
      <% featured.forEach(l => { %>
        <a href="/listings/<%= l._id %>" class="dest-card">
          <div class="dest-card-img" style="background-image:url('<%= l.image.url %>')"></div>
          <div class="dest-card-info">
            <span class="dest-country"><%= l.country %></span>
            <h3><%= l.title %></h3>
          </div>
        </a>
      <% }) %>
    <% } %>
  </div>
</section>

<div style="text-align:center; margin: 60px 0 30px;">
  <h2 style="font-family:var(--serif);font-size:2rem;color:var(--brown);font-weight:400;margin-bottom:10px;">
    Share Your Space with the World
  </h2>
  <p style="font-size:.88rem;color:var(--muted);font-weight:300;margin-bottom:24px;max-width:420px;margin-left:auto;margin-right:auto;line-height:1.8;">
    Have a special place worth discovering? List your stay and let travellers find their perfect escape through you.
  </p>
  <a href="/listings/new" class="btn-add-retreat">Add Your Retreat</a>
</div>


<!-- JOURNEY REDEFINED -->
<section class="features-section">
  <div class="section-header">
    <h2>Journey Redefined</h2>
    <p>More than a booking platform — TripAIO is your travel companion.</p>
  </div>
  <div class="features-grid">
    <% [
      ['fa-hotel','Curated Stays','Hand-selected stays matching your travel aesthetic.'],
      ['fa-map-marked-alt','AI Itineraries','Build your perfect journey with our AI planner.'],
      ['fa-wallet','Budget Tracking','Split expenses effortlessly with companions.'],
      ['fa-compass','Local Insights','Discover hidden gems from seasoned travellers.']
    ].forEach(([icon,title,desc]) => { %>
      <div class="feature-box">
        <i class="fas <%= icon %>"></i>
        <h4><%= title %></h4>
        <p><%= desc %></p>
      </div>
    <% }) %>
  </div>
</section>

<!-- FOOTER -->
<footer class="home-footer">
  <div class="footer-top">
    <div class="footer-brand">
      <h3>TRIPAIO</h3>
      <p>Embrace the journey,<br>for it shapes the destination.</p>
    </div>
    <div class="footer-col">
  <h5>Explore</h5>
  <a style="cursor:default;pointer-events:none;opacity:.5">All Stays</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">Trending</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">Beachfront</a>
</div>
<div class="footer-col">
  <h5>Plan</h5>
  <a style="cursor:default;pointer-events:none;opacity:.5">AI Planner</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">Budget</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">My Trips</a>
</div>
<div class="footer-col">
  <h5>Account</h5>
  <a style="cursor:default;pointer-events:none;opacity:.5">Sign Up</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">Login</a>
  <a style="cursor:default;pointer-events:none;opacity:.5">List Stay</a>
</div>
  </div>
  <div class="footer-base">
    <p>© 2026 TripAIO Private Limited</p>
  </div>
</footer>

<!-- <script>
  console.log("SERVER SAYS CURR USER:", '<%= locals.currUser ? locals.currUser.username : "NOBODY" %>');
</script> -->
<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 60));

  document.querySelectorAll('.cat-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('open'));
      card.classList.add('open');
    });
  });

   const debugEl = document.getElementById('debug-user');
  const userLoggedIn = debugEl.dataset.user !== 'NOBODY';
  console.log("USER FROM DATA ATTR:", debugEl.dataset.user);

  if (!userLoggedIn) {
    document.querySelectorAll(
      'a[href^="/listings"], a[href^="/trip"], .dest-card, .btn-hero-primary, .btn-hero-secondary, .btn-add-retreat'
    ).forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();

        const signin = document.getElementById('signinBtn');
        const signup = document.getElementById('signupBtn');
        [signin, signup].forEach(btn => {
          if (!btn) return;
          btn.style.transform = 'scale(1.18)';
          btn.style.boxShadow = '0 0 0 5px rgba(201,162,39,.55)';
          setTimeout(() => {
            btn.style.transform = '';
            btn.style.boxShadow = '';
          }, 1400);
        });

        if (document.getElementById('authPopup')) return;
        const popup = document.createElement('div');
        popup.id = 'authPopup';
        popup.style.cssText = `
          position:fixed; bottom:32px; left:50%;
          transform:translateX(-50%);
          background:rgba(30,20,10,0.92); color:#fff;
          padding:14px 28px; border-radius:40px;
          font-size:.85rem; z-index:9999;
          box-shadow:0 8px 32px rgba(0,0,0,.3);
        `;
        popup.innerHTML = `✦ Please <a href="/login" style="color:#C9A227;font-weight:600;">Sign In</a> or <a href="/signup" style="color:#C9A227;font-weight:600;">Get Started</a> to continue`;
        document.body.appendChild(popup);
        setTimeout(() => popup.remove(), 3000);
      });
    });
  }
</script>
<script>
  let autoScrolled = false;

  const exploreBtn = document.querySelector('.btn-hero-primary');
  const choose = document.querySelector('.choose-section');

  exploreBtn.addEventListener('mousemove', (e) => {
    if (autoScrolled) return;

    const btnRect = exploreBtn.getBoundingClientRect();

    // when cursor goes below the explore button
    if (e.clientY > btnRect.bottom) {
      autoScrolled = true;
      window.scrollTo({
        top: choose.offsetTop,
        behavior: 'smooth'
      });
    }
  });

 // also works on touch devices
  exploreBtn.addEventListener('touchmove', () => {
    if (autoScrolled) return;
    autoScrolled = true;
    window.scrollTo({
      top: choose.offsetTop,
      behavior: 'smooth'
    });
  });
</script>

<!-- ✅ AUTO SCROLL — works for ALL users, logged in or not -->
<script>
  let heroAutoScrolled = false;
  const chooseSection = document.querySelector('.choose-section');
  const heroSection = document.querySelector('.hero');

  //  OPTION 1 — mouse moves to bottom of hero screen
  heroSection.addEventListener('mousemove', (e) => {
    if (heroAutoScrolled) return;
    if (e.clientY > window.innerHeight * 0.85) {
      heroAutoScrolled = true;
      chooseSection.scrollIntoView({ behavior: 'smooth' });
    }
  });

  // OPTION 2 — scroll based (works on mobile too)
  window.addEventListener('scroll', () => {
    if (heroAutoScrolled) return;
    const heroBottom = heroSection.getBoundingClientRect().bottom;
    if (heroBottom < window.innerHeight * 0.3) {
      heroAutoScrolled = true;
      chooseSection.scrollIntoView({ behavior: 'smooth' });
    }
  });
</script>
<!--  END AUTO SCROLL -->

</body>  <!-- ← body closes here -->
</html>  <!-- ← html closes here -->