<nav style="position:fixed;top:0;left:0;right:0;z-index:999;height:52px;background:rgba(251,247,240,.97);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;">
  <a href="/" style="font-family:var(--serif);font-size:1.2rem;letter-spacing:.1em;color:var(--brown);text-decoration:none;font-weight:600;">TRIPAIO</a>
  <div style="display:flex;gap:16px;margin:0 auto;flex-wrap:wrap;justify-content:center;">
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Staycations</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Plan Trips</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">My Trips</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Budget</a>
  </div>
 
</nav>


<div style="height:52px"></div>
<div class="signup-wrap">

  <!-- LEFT IMAGE SIDE -->
  <div class="signup-img">
    <h2>Begin Your<br>Journey</h2>
    <p>Join thousands of travellers discovering extraordinary stays and planning unforgettable trips.</p>
  </div>

  <!-- RIGHT FORM SIDE -->
  <div class="signup-form-side">
    <a href="/" class="signup-logo">TRIPAIO</a>
    <h1 class="signup-title">Create Account</h1>
    <p class="signup-sub">Your next adventure starts with one step.</p>

    <% if(locals.error && error.length) { %>
      <div class="flash-err"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
    <% } %>

    <form action="/signup" method="POST">
      <div class="f-group">
        <label class="f-label">Username</label>
        <input class="f-input" type="text" name="username" placeholder="Choose a username" required autocomplete="username">
      </div>
      <div class="f-group">
        <label class="f-label">Email</label>
        <input class="f-input" type="email" name="email" placeholder="you@example.com" required autocomplete="email">
      </div>
      <div class="f-group">
        <label class="f-label">Password</label>
        <input class="f-input" type="password" name="password" placeholder="Create a strong password" required autocomplete="new-password">
      </div>
      <button class="btn-auth" type="submit">Create Account</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/login">Sign in →</a></p>
  </div>

</div>
<script>
  const form = document.querySelector('form');
  const email = document.querySelector('input[name="email"]');
  const pass = document.querySelector('input[name="password"]');

  email.addEventListener('input', () => email.value = email.value.toLowerCase());

  form.addEventListener('submit', (e) => {
    const validDomains = ['gmail.com','hotmail.com','yahoo.com','outlook.com','icloud.com'];
    const domain = email.value.split('@')[1];
    if (!domain || !validDomains.includes(domain)) {
      e.preventDefault();
      alert('Use a valid email: @gmail.com, @hotmail.com, @yahoo.com etc');
      return;
    }

    const p = pass.value;
    if (p.length < 8 || !/[0-9]/.test(p) || !/[!@#$%^&*]/.test(p)) {
      e.preventDefault();
      alert('Password needs: 8+ chars, 1 number, 1 special character (!@#$%^&*)');
      return;
    }
  });
</script>
</body>
</html>