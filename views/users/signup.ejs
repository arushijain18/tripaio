


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up — TripAIO</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { margin:0; padding:0; font-family:var(--sans); }
    .signup-wrap { display:flex; height:calc(100vh - 52px); overflow:hidden; }
    .signup-img { flex:1; background:linear-gradient(135deg,rgba(42,157,143,.45),rgba(44,24,16,.55)), url('https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=1400&q=80') center/cover; position:relative; display:flex; flex-direction:column; justify-content:flex-end; padding:52px; }
    .signup-img h2 { font-family:var(--serif); font-size:3rem; color:#fff; font-weight:300; margin-bottom:10px; }
    .signup-img p { font-size:.9rem; color:rgba(255,255,255,.65); font-weight:300; line-height:1.8; max-width:340px; }
    .signup-form-side { width:440px; flex-shrink:0; background:#fff; display:flex; flex-direction:column; justify-content:center; padding:60px 48px; }
    .signup-logo { font-family:var(--serif); font-size:1.4rem; letter-spacing:.1em; color:var(--brown); display:block; margin-bottom:44px; }
    .signup-title { font-family:var(--serif); font-size:2rem; color:var(--brown); margin-bottom:6px; }
    .signup-sub { font-size:.82rem; color:var(--muted); font-weight:300; margin-bottom:32px; }
    .f-group { margin-bottom:16px; }
    .f-label { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--brown-mid); display:block; margin-bottom:6px; }
    .f-input { width:100%; padding:11px 14px; border:1px solid var(--border); border-radius:8px; font-family:var(--sans); font-size:.88rem; color:var(--brown); background:var(--sand-light); outline:none; transition:border-color .3s; }
    .f-input:focus { border-color:var(--terracotta); background:#fff; }
    .btn-auth { width:100%; padding:13px; background:var(--terracotta); color:#fff; font-size:.76rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; border:none; border-radius:7px; cursor:pointer; margin-top:8px; font-family:var(--sans); transition:all .3s; }
    .btn-auth:hover { background:var(--terracotta-dark); transform:translateY(-1px); }
    .auth-switch { text-align:center; margin-top:20px; font-size:.8rem; color:var(--muted); }
    .auth-switch a { color:var(--terracotta); font-weight:500; }
    .flash-err { background:#FEF2F2; border:1px solid #FCA5A5; color:#991B1B; padding:10px 14px; border-radius:8px; font-size:.8rem; margin-bottom:16px; }
  </style>
</head>
<body>

