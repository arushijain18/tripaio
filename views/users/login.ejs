<!-- </nav> -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:999;height:52px;background:rgba(251,247,240,.97);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;">
  <a href="/" style="font-family:var(--serif);font-size:1.2rem;letter-spacing:.1em;color:var(--brown);text-decoration:none;font-weight:600;">TRIPAIO</a>
  <div style="display:flex;gap:16px;margin:0 auto;flex-wrap:wrap;justify-content:center;">
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Staycations</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Plan Trips</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">My Trips</a>
    <a href="/" style="font-size:.62rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none">Budget</a>
  </div>
  <a href="/signup" style="font-size:.62rem;font-weight:600;padding:6px 12px;border:1.5px solid var(--terracotta);color:var(--terracotta);border-radius:4px;text-decoration:none;white-space:nowrap;">Sign Up</a>
</nav>

<div style="height:52px"></div>
<div class="login-wrap">

  <!-- LEFT IMAGE SIDE -->
  <div class="login-img">
    <h2>Welcome Back,<br>Wanderer</h2>
    <p>Your next adventure awaits. Sign in to explore curated stays and manage your itineraries.</p>
  </div>

  <!-- RIGHT FORM SIDE -->
  <div class="login-form-side">
    <a href="/" class="login-logo">TRIPAIO</a>
    <h1 class="login-title">Sign In</h1>
    <p class="login-sub">Continue your journey from where you left off.</p>

    <% if(locals.error && error.length) { %>
      <div class="flash-err"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
    <% } %>

    <form action="/login" method="POST">
      <div class="f-group">
        <label class="f-label">Username</label>
        <input class="f-input" type="text" name="username" placeholder="Your username" required autocomplete="username">
      </div>
      <div class="f-group">
        <label class="f-label">Password</label>
        <input class="f-input" type="password" name="password" placeholder="Your password" required autocomplete="current-password">
      </div>
      <button class="btn-auth" type="submit">Sign In</button>
    </form>

    <p class="auth-switch">New here? <a href="/signup">Create an account →</a></p>
  </div>

</div>
</body>
</html>