<% layout('layouts/boilerplate') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
  .day-card{border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.1);margin-bottom:2rem}
  .day-header{padding:1rem 1.5rem;color:#fff}
  .day-body{padding:1.5rem;background:#fff}
  .badge-pill{padding:5px 14px;border-radius:20px;font-size:.83rem}
  .weather-pill{background:#fff3e0;color:#e65100}
  .cost-pill{background:#e8f5e9;color:#1b5e20}
  .place-tag{background:#f3f4f6;border-radius:8px;padding:3px 10px;font-size:.8rem;margin:2px}
  .map-frame{width:100%;height:190px;border:none;border-radius:10px;margin-top:.8rem}
  .summary-box{background:linear-gradient(135deg,#1a3a2a,#2d6a4f);color:#fff;border-radius:14px;padding:1.8rem;margin-bottom:2rem}
  .header-colors-0{background:#1a6b3a}.header-colors-1{background:#1a3a6b}.header-colors-2{background:#6b1a3a}
</style>

<div class="container my-5">

  <!-- Header -->
  <h3>
    <i class="fa-solid fa-map-location-dot me-2 text-success"></i>
    Trip to <strong><%= itinerary.destination %></strong>
  </h3>

  <p class="text-muted">
    <%= days %> days • <%= people %> people • ₹<%= budget %>
  </p>

  <!-- Days -->
  <% const times = [
    {key:'morning', icon:'sun', color:'#f59e0b'},
    {key:'afternoon', icon:'cloud-sun', color:'#f97316'},
    {key:'evening', icon:'moon', color:'#6366f1'}
  ]; %>

  <!--  FIX 1: Check if itinerary.days exists -->
  <% if(itinerary && itinerary.days){ %>

    <% itinerary.days.forEach((day,i)=>{ %>
    <div class="day-card">

      <div class="day-header header-colors-<%= i%3 %>">
        Day <%= day.day %> — <%= day.title %>
      </div>

      <div class="day-body">

        <!-- Info -->
        <div class="d-flex gap-2 mb-3">
          <!--  FIX 2: fallback text if undefined -->
          <span class="badge-pill weather-pill">🌤 <%= day.weather || "N/A" %></span>
          <span class="badge-pill cost-pill">₹<%= day.estimatedCost || 0 %></span>
        </div>

        <!-- Schedule -->
        <% times.forEach(t=>{ %>
          <p style="font-weight:600;color:#444">
            <i class="fa-solid fa-<%= t.icon %>" style="color:<%= t.color %>"></i>
            <%= t.key.charAt(0).toUpperCase()+t.key.slice(1) %>
          </p>

          <!--  FIX 3: safe access -->
          <p class="ms-3"><%= day[t.key] || "No data" %></p>
        <% }) %>

        <!-- Places -->
        <div>
          <!--  FIX 4: check if places exists -->
          <% if(day.places){ day.places.forEach(p=>{ %>
            <span class="place-tag"><%= p %></span>
          <% }) } else { %>
            <p>No places available</p>
          <% } %>
        </div>

        <!-- Map -->
        <!--  FIX 5: avoid crash if places empty -->
        <% if(day.places && day.places.length > 0){ %>
          <iframe class="map-frame"
            src="https://maps.google.com/maps?q=<%= encodeURIComponent(day.places[0] + ' ' + itinerary.destination) %>&output=embed">
          </iframe>
        <% } %>

      </div>
    </div>
    <% }) %>

  <% } else { %>
    <!--  FIX 6: fallback UI -->
    <p>No itinerary data found</p>
  <% } %>

  <!-- Summary -->
  <div class="summary-box">
    <h5>Trip Summary</h5>

    <p>Budget: ₹<%= budget %></p>

    <!--  FIX 7: safe comparison -->
    <p class="<%= (itinerary.totalEstimatedCost || 0) > budget ? 'text-danger':'text-success' %>">
      Total: ₹<%= itinerary.totalEstimatedCost || 0 %>
    </p>

    <% if(itinerary.tips){ %>
      <p>💡 <%= itinerary.tips %></p>
    <% } %>
  </div>

</div>